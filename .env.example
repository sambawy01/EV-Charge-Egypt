# --- CLIENT-SIDE (safe to ship in app bundle) ---
# These EXPO_PUBLIC_* vars are inlined into the JavaScript bundle at build time.
# Only put values here that are safe to expose to every browser/device.

EXPO_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
EXPO_PUBLIC_SUPABASE_ANON_KEY=your-anon-key-here

# Google Maps JS key. Restrict by HTTP referrer in the Google Cloud Console.
EXPO_PUBLIC_GOOGLE_MAPS_KEY=your-google-maps-key

# Optional. OpenChargeMap works without a key but has lower rate limits.
# Register at https://openchargemap.org to get a free key.
EXPO_PUBLIC_OCM_API_KEY=

# --- SERVER-SIDE ONLY (NEVER put these in this file) ---
#
# The following secrets must NEVER be prefixed with EXPO_PUBLIC_ and must NEVER
# live in this .env file (Expo would inline any EXPO_PUBLIC_* into the bundle).
# They belong only in the Supabase Edge Functions secret store. Set them with:
#
#   supabase secrets set ANTHROPIC_API_KEY=sk-ant-...
#   supabase secrets set SUPABASE_SERVICE_ROLE_KEY=sb_secret_...
#   supabase secrets set SYNC_CRON_SECRET=$(openssl rand -hex 32)
#   supabase secrets set PAYMENT_GATEWAY_MODE=simulate   # or 'live' once integrated
#
# Verify with:
#
#   supabase secrets list
